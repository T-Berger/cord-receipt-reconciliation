# Never commit real credentials. Copy this file to .env or export the variables.
MISTRAL_API_KEY=

# Optional: when all three are configured, traces and evaluation scores are
# uploaded to Langfuse. A local JSON trace is always written as well.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=receipt-reconciliation
